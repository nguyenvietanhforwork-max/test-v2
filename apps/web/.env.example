# Atlas web — environment template.
# Copy to .env.local for local dev. In Vercel, set these in:
#   Project → Settings → Environment Variables

# Backend API base (no trailing slash).
# For local dev:        http://localhost:8000/api/v1
# For Vercel preview:   https://your-api.example.com/api/v1  (replace with real backend)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# WebSocket endpoint for real-time pipeline events.
# Must use wss:// in production (browsers block insecure WS from https pages).
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/stream

# Build-time flag — set to "true" in Vercel until backend is live.
# When true, the app falls back to deterministic mock data so the UI renders.
NEXT_PUBLIC_USE_MOCKS=true

# Optional: site URL used for canonical tags + open-graph.
NEXT_PUBLIC_SITE_URL=https://atlas.vercel.app

# ---------- Supabase (optional but recommended for production) ----------
# Find these in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase's newer publishable key name is also supported by the code:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
