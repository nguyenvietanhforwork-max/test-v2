# Atlas API — environment template.
# Use this when deploying to Railway/Render/Fly.io. Supabase-first.

# ---------- runtime ----------
ENV=prod
LOG_LEVEL=info

# ---------- Supabase (recommended) ----------
# Paste the Connection Pooler URL from: Supabase → Project Settings → Database.
# Use the "Transaction" pooler on port 6543 for serverless / stateless workers.
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_SECRET_KEY=sb_secret_...
USE_SUPABASE_REALTIME=true

# ---------- Storage (PDFs) ----------
# "supabase" uses Supabase Storage; "minio" uses self-hosted MinIO.
STORAGE_BACKEND=supabase
SUPABASE_STORAGE_BUCKET=atlas-pdfs
PDF_SERVICE_URL=https://atlas-pdf.onrender.com

# ---------- Redis (still needed for Celery broker) ----------
# Use Upstash (free tier) — paste REST URL or native protocol URL.
REDIS_URL=rediss://default:<token>@<your>.upstash.io:6379

# ---------- Meilisearch ----------
# Use Meilisearch Cloud, or self-host.
MEILI_HOST=https://<your>.meilisearch.io
MEILI_MASTER_KEY=<master-key>

# ---------- LLM ----------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEFAULT_MODEL=claude-sonnet-4-6
FALLBACK_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large

# ---------- Auth ----------
JWT_SECRET=use-a-long-random-string

# ---------- CORS ----------
# Comma-separated list. Add every Vercel preview branch you want to allow.
CORS_ORIGINS=["https://atlas.vercel.app","http://localhost:3000"]
