# Atlas — environment template. Copy to `.env` and fill in the secrets.

# ---------- core ----------
NODE_ENV=development
LOG_LEVEL=info
ENV=dev

# ---------- auth ----------
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# ---------- database ----------
POSTGRES_HOST=postgres
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas
POSTGRES_DB=atlas

# ---------- redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- meilisearch ----------
MEILI_HOST=http://meili:7700
MEILI_MASTER_KEY=change-me-meili-master-key

# ---------- LLM ----------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEFAULT_MODEL=claude-sonnet-4-6
FALLBACK_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large

# ---------- MinIO ----------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=atlas-pdfs
MINIO_SECURE=false

# ---------- vault paths (inside containers) ----------
VAULT_RAW=/vault/raw
VAULT_WIKI=/vault/wiki
VAULT_PROCESSED=/vault/Processed

# ---------- frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/stream
