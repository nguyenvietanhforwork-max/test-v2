# ─────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
TIMEZONE=Asia/Ho_Chi_Minh

# ─────────────────────────────────────────────
# Database (Supabase Postgres + pgvector)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db.<project>.supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres:password@db.<project>.supabase.co:5432/postgres
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─────────────────────────────────────────────
# Redis / Queue (Upstash or Railway Redis)
# ─────────────────────────────────────────────
REDIS_URL=redis://default:password@host:6379
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ─────────────────────────────────────────────
# AI providers
# ─────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536
SUMMARIZATION_MODEL=claude-sonnet-4-6
CLASSIFICATION_MODEL=claude-haiku-4-5-20251001
REPORT_MODEL=claude-opus-4-6

# ─────────────────────────────────────────────
# n8n
# ─────────────────────────────────────────────
N8N_WEBHOOK_URL=https://n8n.example.com/webhook
N8N_API_KEY=

# ─────────────────────────────────────────────
# Vault / Obsidian
# ─────────────────────────────────────────────
VAULT_PATH=/data/vault
VAULT_RAW_DIR=raw
VAULT_WIKI_DIR=wiki
VAULT_PROCESSED_DIR=Processed
VAULT_ARCHIVE_DIR=raw/old news

# ─────────────────────────────────────────────
# Services (internal URLs)
# ─────────────────────────────────────────────
API_BASE_URL=http://api:8000
AGENTS_BASE_URL=http://agents:8001
PDF_ENGINE_URL=http://pdf-engine:4000
DASHBOARD_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Search
# ─────────────────────────────────────────────
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=

# ─────────────────────────────────────────────
# Auth (Supabase Auth or Clerk)
# ─────────────────────────────────────────────
JWT_ISSUER=https://<project>.supabase.co/auth/v1
JWT_AUDIENCE=authenticated

# ─────────────────────────────────────────────
# Public envs (dashboard)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_WS_URL=wss://api.example.com/ws
