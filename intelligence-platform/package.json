{
  "name": "intelligence-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Production-grade AI intelligence operating system on top of an Obsidian vault",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml,yaml}\"",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "compose:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "compose:down": "docker compose -f infra/docker/docker-compose.yml down",
    "compose:logs": "docker compose -f infra/docker/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
