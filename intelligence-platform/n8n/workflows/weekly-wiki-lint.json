{
  "name": "weekly-wiki-lint",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "0 22 * * 0" }] }
      },
      "id": "cron",
      "name": "Sunday 22:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 320]
    },
    {
      "parameters": {
        "url": "={{$env.AGENTS_BASE_URL}}/wiki-lint",
        "method": "POST",
        "options": { "timeout": 600000 }
      },
      "id": "lint",
      "name": "POST /wiki-lint",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 320]
    }
  ],
  "connections": {
    "Sunday 22:00": { "main": [[{ "node": "POST /wiki-lint", "type": "main", "index": 0 }]] }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "intelligence" }]
}
