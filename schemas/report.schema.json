{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://atlas.local/schemas/report.schema.json",
  "title": "Intelligence Report",
  "description": "Frontmatter schema for every content/reports/*.md file. Per ADR-009, all semantic fields are populated by the pipeline even when downstream consumers (graph, embeddings, related-reports) are not yet active.",
  "type": "object",
  "required": ["id", "type", "date", "title", "sources", "generated_at"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable identifier. Pattern: report-YYYY-MM-DD-NNN or report-YYYY-MM-DD-<slug>.",
      "pattern": "^report-[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9-]+$"
    },
    "type": { "type": "string", "const": "report" },
    "kind": { "type": "string", "enum": ["daily-brief", "weekly-synthesis", "ad-hoc", "deep-dive"] },
    "date": { "type": "string", "format": "date" },
    "title": { "type": "string", "minLength": 8 },
    "subtitle": { "type": "string" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "description": "Path to raw/ source — e.g. 'raw/news/2026-05-18/foo.md'." }
    },
    "entities": {
      "type": "array",
      "items": { "$ref": "semantic.schema.json#/definitions/Entity" }
    },
    "themes": {
      "type": "array",
      "items": { "$ref": "semantic.schema.json#/definitions/Theme" }
    },
    "topics": {
      "type": "array",
      "items": { "$ref": "semantic.schema.json#/definitions/Topic" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "industry": {
      "type": "string",
      "description": "Primary industry slug, e.g. 'real-estate', 'banking', 'logistics'."
    },
    "geography": {
      "type": "array",
      "items": { "type": "string" },
      "description": "ISO country codes or region slugs."
    },
    "related_reports": {
      "type": "array",
      "items": { "$ref": "semantic.schema.json#/definitions/RelatedReport" }
    },
    "signal_score": {
      "$ref": "semantic.schema.json#/definitions/Score",
      "description": "How much this changes an informed reader's view. 0=no impact, 1=transformative."
    },
    "novelty_score": {
      "$ref": "semantic.schema.json#/definitions/Score",
      "description": "How non-obvious / unexpected. 0=widely-reported obvious news, 1=genuinely new angle."
    },
    "confidence": { "$ref": "semantic.schema.json#/definitions/Confidence" },
    "embeddings_ref": { "$ref": "semantic.schema.json#/definitions/EmbeddingRef" },
    "prompt_version": { "$ref": "semantic.schema.json#/definitions/PromptVersion" },
    "model": { "$ref": "semantic.schema.json#/definitions/ModelId" },
    "template_version": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "mini_report": {
      "type": "object",
      "description": "The compact dashboard-card body — see prompts/formatting/intelligence-letter.md.",
      "required": ["topic_sentence", "bullets"],
      "properties": {
        "topic_sentence": { "type": "string", "minLength": 40 },
        "bullets": {
          "type": "array",
          "minItems": 3,
          "maxItems": 6,
          "items": { "type": "string", "minLength": 20 }
        }
      },
      "additionalProperties": false
    },
    "author": { "type": "string", "description": "Original journalist if from a single source." },
    "source_publication": { "type": "string", "examples": ["vneconomy.vn", "vietstock.vn", "Bloomberg"] },
    "published_at": { "type": "string", "format": "date" },
    "url": { "type": "string", "format": "uri" },
    "language": { "type": "string", "examples": ["vi", "en"] }
  },
  "additionalProperties": false
}
